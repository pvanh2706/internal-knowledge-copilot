{
  "Database": {
    "SqlitePath": "./data/internal-knowledge-copilot.db"
  },
  "Storage": {
    "RootPath": "./storage",
    "MaxUploadBytes": 20971520,
    "AllowedExtensions": [ ".pdf", ".docx", ".md", ".markdown", ".txt" ]
  },
  "Chroma": {
    "BaseUrl": "http://localhost:8000",
    "Collection": "knowledge_chunks",
    "Tenant": "default_tenant",
    "Database": "default_database"
  },
  "BackgroundJobs": {
    "PollSeconds": 5,
    "MaxAttempts": 3
  },
  "AiProvider": {
    "Name": "mock",
    "BaseUrl": "https://api.openai.com/v1",
    "ApiKey": "",
    "ApiKeyHeaderName": "Authorization",
    "ChatEndpointMode": "chat-completions",
    "ChatModel": "gpt-5.5",
    "FastModel": "gpt-5.5",
    "EmbeddingModel": "text-embedding-3-large",
    "EmbeddingDimension": 3072,
    "ReasoningEffort": "medium",
    "Temperature": 0.2,
    "MaxOutputTokens": 2500,
    "TimeoutSeconds": 60
  },
  "Jwt": {
    "Issuer": "InternalKnowledgeCopilot",
    "Audience": "InternalKnowledgeCopilot",
    "SigningKey": "local-development-signing-key-change-before-production",
    "AccessTokenMinutes": 120
  },
  "Seed": {
    "Enabled": true,
    "AdminEmail": "admin@example.local",
    "AdminPassword": "ChangeMe123!",
    "ReviewerEmail": "reviewer@example.local",
    "ReviewerPassword": "ChangeMe123!",
    "UserEmail": "user@example.local",
    "UserPassword": "ChangeMe123!"
  },
  "Cors": {
    "AllowedOrigins": [ "http://localhost:5173" ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
