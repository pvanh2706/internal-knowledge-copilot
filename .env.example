# Internal Knowledge Copilot environment template
# Copy to a local environment file or map these values into appsettings/user secrets.
# Do not commit real secrets.

# ASP.NET Core
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://localhost:5000

# Frontend
VITE_API_BASE_URL=http://localhost:5000/api

# Database
Database__SqlitePath=./data/internal-knowledge-copilot.db

# File storage
Storage__RootPath=./storage
Storage__MaxUploadBytes=20971520
Storage__AllowedExtensions__0=.pdf
Storage__AllowedExtensions__1=.docx
Storage__AllowedExtensions__2=.md
Storage__AllowedExtensions__3=.markdown
Storage__AllowedExtensions__4=.txt

# Auth
Jwt__Issuer=InternalKnowledgeCopilot
Jwt__Audience=InternalKnowledgeCopilot
Jwt__SigningKey=replace-with-local-development-signing-key
Jwt__AccessTokenMinutes=120

# ChromaDB
Chroma__BaseUrl=http://localhost:8000
Chroma__Collection=knowledge_chunks
Chroma__Tenant=default_tenant
Chroma__Database=default_database

# AI provider
# Use mock for offline local tests. Use openai/openai-compatible/local to call a real LLM API.
# When switching from mock embeddings to a real embedding model, use a fresh Chroma collection
# such as knowledge_chunks_v2 because vector dimensions cannot be mixed in one collection.
AiProvider__Name=mock
AiProvider__BaseUrl=https://api.openai.com/v1
AiProvider__ApiKey=replace-with-real-key-outside-git
AiProvider__ApiKeyHeaderName=Authorization
AiProvider__ChatEndpointMode=chat-completions
AiProvider__ChatModel=gpt-5.5
AiProvider__FastModel=gpt-5.5
AiProvider__EmbeddingProviderName=openai-compatible
AiProvider__EmbeddingBaseUrl=https://api.openai.com/v1
AiProvider__EmbeddingApiKey=replace-with-real-key-outside-git
AiProvider__EmbeddingApiKeyHeaderName=Authorization
AiProvider__EmbeddingModel=text-embedding-3-large
AiProvider__EmbeddingDimension=3072
AiProvider__ReasoningEffort=medium
AiProvider__Temperature=0.2
AiProvider__MaxOutputTokens=2500
AiProvider__TimeoutSeconds=60

# Background jobs
BackgroundJobs__PollSeconds=5
BackgroundJobs__MaxAttempts=3

# Data reset
# Disabled by default outside Development. Enable temporarily only when clearing test data.
DataReset__Enabled=false
DataReset__ConfirmationPhrase=RESET TEST DATA

# Development seed data
Seed__Enabled=true
Seed__AdminEmail=admin@example.local
Seed__AdminPassword=ChangeMe123!
Seed__ReviewerEmail=reviewer@example.local
Seed__ReviewerPassword=ChangeMe123!
Seed__UserEmail=user@example.local
Seed__UserPassword=ChangeMe123!
