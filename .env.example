# Internal Knowledge Copilot environment template
# Copy to a local environment file or map these values into appsettings/user secrets.
# Do not commit real secrets.

# ASP.NET Core
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://localhost:5000

# Frontend
VITE_API_BASE_URL=http://localhost:5000/api

# Database
DATABASE_PROVIDER=sqlite
SQLITE_DB_PATH=./data/internal-knowledge-copilot.db

# File storage
STORAGE_ROOT=./storage
MAX_UPLOAD_BYTES=20971520
ALLOWED_UPLOAD_EXTENSIONS=.pdf,.docx,.md,.markdown,.txt

# Auth
JWT_ISSUER=InternalKnowledgeCopilot
JWT_AUDIENCE=InternalKnowledgeCopilot
JWT_SIGNING_KEY=replace-with-local-development-signing-key
JWT_ACCESS_TOKEN_MINUTES=120

# ChromaDB
CHROMA_BASE_URL=http://localhost:8000
CHROMA_COLLECTION=knowledge_chunks

# AI provider
AI_PROVIDER=replace-with-provider-name
AI_API_BASE_URL=
AI_API_KEY=replace-with-real-key-outside-git
AI_CHAT_MODEL=
AI_EMBEDDING_MODEL=
AI_EMBEDDING_DIMENSION=

# Background jobs
BACKGROUND_JOB_POLL_SECONDS=5
BACKGROUND_JOB_MAX_ATTEMPTS=3

# Development seed data
SEED_DEVELOPMENT_DATA=true
SEED_ADMIN_EMAIL=admin@example.local
SEED_ADMIN_PASSWORD=ChangeMe123!
SEED_REVIEWER_EMAIL=reviewer@example.local
SEED_REVIEWER_PASSWORD=ChangeMe123!
SEED_USER_EMAIL=user@example.local
SEED_USER_PASSWORD=ChangeMe123!
