    {
      "name": "06 Workflow Copilot - JWT User",
      "description": "Luồng workflow recommendation hiện chuyên cho CRM deal stage changed. Cần applicationId, externalObjectId và quyền external object hợp lệ.",
      "item": [
        {
          "name": "Deal Stage Changed",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Workflow recommendation returned', function () {",
                  "  pm.response.to.have.status(200);",
                  "  const json = pm.response.json();",
                  "  pm.collectionVariables.set('recommendationId', json.id);",
                  "});"
