          "response": []
        },
        {
          "name": "List Workflow Recommendations",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-Tenant-Code",
                "value": "{{tenantCode}}",
                "type": "text"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{userJwt}}",
                "type": "text"
              }
            ],
            "url": "{{baseUrl}}/workflow-copilot/recommendations?applicationId={{applicationId}}&objectType=deal&externalObjectId={{dealExternalObjectId}}",
            "description": "Liệt kê recommendation theo application/object. Dùng để kiểm tra recommendation đã được lưu và audit được."
          },
          "response": []
        },
        {
          "name": "Submit Workflow Recommendation Feedback",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "X-Tenant-Code",
                "value": "{{tenantCode}}",
                "type": "text"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{userJwt}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"value\": \"Helpful\",\n  \"note\": \"Postman test: recommendation hợp lý cho stage Proposal.\"\n}"
            },
            "url": "{{baseUrl}}/workflow-copilot/recommendations/{{recommendationId}}/feedback",
            "description": "Gửi feedback cho recommendation. Giá trị hiện hành: `Helpful`, `NotHelpful`, `NeedsReview`."
          },
          "response": []
        }
      ]
    }
