              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "X-Tenant-Code",
                "value": "{{tenantCode}}",
                "type": "text"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{userJwt}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"applicationId\": \"{{applicationId}}\",\n  \"externalObjectId\": \"{{dealExternalObjectId}}\",\n  \"fromStage\": \"Qualification\",\n  \"toStage\": \"Proposal\",\n  \"idempotencyKey\": \"deal-stage:{{dealExternalObjectId}}:Proposal:{{$timestamp}}\",\n  \"occurredAt\": \"{{$isoTimestamp}}\",\n  \"dealContextJson\": \"{\\\"customer\\\":\\\"ABC\\\",\\\"amount\\\":120000000,\\\"stage\\\":\\\"Proposal\\\"}\",\n  \"notesJson\": \"[{\\\"text\\\":\\\"Customer requested payment terms.\\\"}]\",\n  \"tasksJson\": \"[]\",\n  \"emailsJson\": \"[]\",\n  \"callsJson\": \"[]\",\n  \"recentActivitiesJson\": \"[{\\\"type\\\":\\\"note\\\",\\\"summary\\\":\\\"Need legal review.\\\"}]\"\n}"
            },
            "url": "{{baseUrl}}/workflow-copilot/deal-stage-changed",
            "description": "Tạo recommendation khi deal đổi stage. Response gồm recommendedNextSteps, risks, suggestedTasks, wonLostSignals và sources. Đây là reasoning-based recommendation, không phải predictive ML."
